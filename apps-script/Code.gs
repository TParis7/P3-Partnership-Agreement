/* ============================================================================
   P3 Institutional Partnership Agreement  Google Docs generator
   Apps Script Web App. Receives the document block-model from the web form and
   builds a formatted, pre-filled Google Doc, returning its URL.
   Formatting matches the original suite: centered ALL-CAPS black titles/headings,
   black body, P3 logo on the cover; inserted values highlighted in crimson.

   -- TO UPDATE AN EXISTING DEPLOYMENT (keep the same URL) ---------------------
   Paste this file over the old code, then:
   Deploy > Manage deployments > (edit) edit > Version: New version > Deploy.
   ============================================================================ */

var SECRET    = "p3doc_a881cb178a909f0cac2f59c5ab90afe2992c6179"; // must match config.js
var FOLDER_ID = "";                  // optional Drive folder id to file docs into
var SHARING   = "ANYONE_WITH_LINK";  // "ANYONE_WITH_LINK" | "DOMAIN" | "PRIVATE"

// colors  headings/titles are black to match the original; crimson stays for inserted values
var C = { black: "#000000", blue: "#1155CC", crimson: "#B82E2E", crimsonBright: "#D93A3A", muted: "#8a7f86", gray: "#999999" };

var LOGO_B64 = "";       // P3 horizontal logo (420px), injected at build time

function doGet(e) {
  if (e && e.parameter && e.parameter.action === "ping") return json({ ok: true, pong: "P3 agreement generator alive" });
  return json({ ok: false, error: "POST the document model to this endpoint. Use ?action=ping to health-check." });
}

function doPost(e) {
  try {
    var body = JSON.parse(e.postData.contents);
    if (body.secret !== SECRET) return json({ ok: false, error: "unauthorized" });
    if (body.action === "ping") return json({ ok: true, pong: "P3 agreement generator alive" });
    if (body.action !== "create") return json({ ok: false, error: "unknown action: " + body.action });
    var res = createDoc(body.model || [], body.filename || "P3 Partnership Agreement", body.highlight !== false);
    return json({ ok: true, url: res.url, id: res.id });
  } catch (err) {
    return json({ ok: false, error: String(err && err.stack || err) });
  }
}

function json(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);
}

/* -------------------------------------------------------------------------- */
function createDoc(model, filename, highlight) {
  var doc = DocumentApp.create(filename);
  var body = doc.getBody();
  body.setMarginTop(54).setMarginBottom(54).setMarginLeft(58).setMarginRight(58);
  body.setAttributes(baseAttrs());
  var seedPara = body.getChild(0); // create() leaves one empty paragraph

  model.forEach(function (b) { renderBlock(body, b, highlight); });

  try {
    if (body.getNumChildren() > 1 && seedPara.getType() === DocumentApp.ElementType.PARAGRAPH
        && seedPara.asParagraph().getText() === "") body.removeChild(seedPara);
  } catch (ignore) {}

  doc.saveAndClose();
  applySharingAndFolder(doc.getId());
  return { url: doc.getUrl(), id: doc.getId() };
}

function renderBlock(body, b, highlight) {
  switch (b.t) {
    case "title":
      // P3 logo (centered) above the suite/MOU title
      try {
        if (typeof LOGO_B64 === "string" && LOGO_B64.length > 100) {
          var blob = Utilities.newBlob(Utilities.base64Decode(LOGO_B64), "image/png", "p3.png");
          var lp = body.appendParagraph("");
          lp.setAlignment(DocumentApp.HorizontalAlignment.CENTER);
          var img = lp.appendInlineImage(blob);
          var ratio = img.getHeight() / img.getWidth();
          img.setWidth(150);
          img.setHeight(Math.round(150 * ratio));
          lp.setSpacingBefore(60);
        }
      } catch (eLogo) {}
      para(body, (b.text || "").toUpperCase(), { heading: DocumentApp.ParagraphHeading.TITLE,
        align: DocumentApp.HorizontalAlignment.CENTER, attrs: attr({ size: 22, bold: true, color: C.black }), spaceBefore: 10 });
      break;
    case "coverMeta":
      (b.lines || []).forEach(function (l, i) {
        para(body, (l || "").toUpperCase(), { align: DocumentApp.HorizontalAlignment.CENTER,
          attrs: attr({ size: i === 0 ? 11 : 9.5, bold: true, color: i === 1 ? C.blue : C.black }) });
      });
      break;
    case "coverParty":
      richPara(body, [{ text: b.label + ":  ", attrs: attr({ color: C.muted }) },
                      { text: b.value, attrs: attr({ bold: true }) }],
        { align: DocumentApp.HorizontalAlignment.CENTER, spaceBefore: 10, highlight: highlight });
      break;
    case "note":
      para(body, b.text, { align: DocumentApp.HorizontalAlignment.CENTER, spaceBefore: 16,
        attrs: attr({ size: 8.5, italic: true, color: C.gray }) });
      break;
    case "pageBreak":
      body.appendPageBreak();
      break;
    case "h1":
      para(body, (b.text || "").toUpperCase(), { heading: DocumentApp.ParagraphHeading.HEADING1,
        align: DocumentApp.HorizontalAlignment.CENTER, attrs: attr({ size: 15, bold: true, color: C.black }), spaceBefore: 8, spaceAfter: 12 });
      break;
    case "h2":
      para(body, (b.text || "").toUpperCase(), { heading: DocumentApp.ParagraphHeading.HEADING2,
        attrs: attr({ size: 12, bold: true, color: C.black }), spaceBefore: 10, spaceAfter: 3 });
      break;
    case "h3":
      para(body, (b.text || "").toUpperCase(), { heading: DocumentApp.ParagraphHeading.HEADING3,
        attrs: attr({ size: 10.5, bold: true, color: C.black }), spaceBefore: 12, spaceAfter: 4 });
      break;
    case "p":
      richPara(body, (b.runs || []).map(function (r) {
        return { text: r.text, fill: r.fill, attrs: (r.fill || r.bold) ? attr({ bold: true }) : null };
      }), { highlight: highlight, justify: true });
      break;
    case "bullets":
      (b.items || []).forEach(function (it) { listItem(body, it, DocumentApp.GlyphType.BULLET); });
      break;
    case "numbered":
      (b.items || []).forEach(function (it) { listItem(body, it, DocumentApp.GlyphType.NUMBER); });
      break;
    case "field":
      richPara(body, [{ text: b.label + ":  ", attrs: attr({ bold: true }) },
        { text: b.value, fill: b.filled, attrs: b.filled ? attr({ bold: true }) : attr({ color: C.gray }) }],
        { highlight: highlight, spaceAfter: 3 });
      break;
    case "check":
      richPara(body, [
        { text: (b.checked ? String.fromCharCode(0x2611) + "  " : String.fromCharCode(0x2610) + "  "), attrs: attr({ color: b.checked ? C.crimsonBright : C.muted }) },
        { text: b.text, attrs: attr({ bold: !!b.checked }) }
      ], { spaceAfter: 2 });
      break;
    case "sig":
      renderSig(body, b, highlight);
      break;
  }
}

/* ---- signature: borderless 2-column table -------------------------------- */
function renderSig(body, b, highlight) {
  var table = body.appendTable([["", ""]]);
  table.setBorderWidth(0);
  fillSigCell(table.getCell(0, 0), b.leftHead, b.rows, "left", highlight);
  fillSigCell(table.getCell(0, 1), b.rightHead, b.rows, "right", highlight);
}
function fillSigCell(cell, head, rows, side, highlight) {
  cell.setPaddingTop(6).setPaddingBottom(6).setPaddingLeft(2).setPaddingRight(12);
  var first = cell.getChild(0).asParagraph();
  first.setText(head);                       // setText() returns void  do not chain
  first.setAttributes(attr({ size: 9.5, bold: true, color: C.black }));
  first.setSpacingAfter(8);
  rows.forEach(function (r) {
    var val = side === "left" ? r.left : r.right;
    var runs = [{ text: r.label + ":  ", attrs: attr({ size: 9, bold: true }) }];
    if (val) runs.push({ text: val, fill: true, attrs: attr({ size: 9, bold: true }) });
    else runs.push({ text: "______________________", attrs: attr({ size: 9, color: "#bbbbbb" }) });
    var p = cell.appendParagraph("");
    writeRuns(p, runs, highlight);
    p.setAttributes(attr({ size: 9 }));
    p.setSpacingAfter(7);
  });
}

/* ---- paragraph helpers --------------------------------------------------- */
function para(body, text, o) {
  o = o || {};
  var p = body.appendParagraph(text || "");
  if (o.heading) p.setHeading(o.heading);
  if (o.align) p.setAlignment(o.align);
  if (o.attrs) p.setAttributes(o.attrs);
  if (o.spaceBefore != null) p.setSpacingBefore(o.spaceBefore);
  if (o.spaceAfter != null) p.setSpacingAfter(o.spaceAfter);
  return p;
}
function richPara(body, runs, o) {
  o = o || {};
  var p = body.appendParagraph("");
  if (o.align) p.setAlignment(o.align);
  else if (o.justify) p.setAlignment(DocumentApp.HorizontalAlignment.JUSTIFY);
  writeRuns(p, runs, o.highlight);
  p.setSpacingAfter(o.spaceAfter != null ? o.spaceAfter : 6);
  if (o.spaceBefore != null) p.setSpacingBefore(o.spaceBefore);
  return p;
}
function writeRuns(p, runs, highlight) {
  var text = p.editAsText();
  runs.forEach(function (r) {
    if (!r.text) return;
    var start = text.getText().length;
    text.appendText(r.text);
    var end = text.getText().length - 1;
    if (end < start) return;
    var a = r.attrs ? cloneAttr(r.attrs) : {};
    if (r.fill && highlight) {
      a[DocumentApp.Attribute.FOREGROUND_COLOR] = C.crimson;
      a[DocumentApp.Attribute.UNDERLINE] = true;
      a[DocumentApp.Attribute.BOLD] = true;
    }
    if (Object.keys(a).length) text.setAttributes(start, end, a);
  });
}
function listItem(body, text, glyph) {
  var li = body.appendListItem(text);
  li.setGlyphType(glyph);
  li.setNestingLevel(0);
  li.setAttributes(attr({ size: 10 }));
  li.setSpacingAfter(2);
  return li;
}

/* ---- attribute helpers --------------------------------------------------- */
function baseAttrs() {
  var a = {};
  a[DocumentApp.Attribute.FONT_FAMILY] = "Arial";
  a[DocumentApp.Attribute.FONT_SIZE] = 10;
  a[DocumentApp.Attribute.FOREGROUND_COLOR] = "#000000";
  return a;
}
function attr(o) {
  var a = {};
  if (o.size != null) a[DocumentApp.Attribute.FONT_SIZE] = o.size;
  if (o.bold != null) a[DocumentApp.Attribute.BOLD] = o.bold;
  if (o.italic != null) a[DocumentApp.Attribute.ITALIC] = o.italic;
  if (o.color != null) a[DocumentApp.Attribute.FOREGROUND_COLOR] = o.color;
  a[DocumentApp.Attribute.FONT_FAMILY] = "Arial";
  return a;
}
function cloneAttr(a) { var c = {}; for (var k in a) c[k] = a[k]; return c; }

/* ---- sharing / folder ---------------------------------------------------- */
function applySharingAndFolder(id) {
  try {
    var file = DriveApp.getFileById(id);
    if (FOLDER_ID) { try { file.moveTo(DriveApp.getFolderById(FOLDER_ID)); } catch (e) {} }
    if (SHARING === "ANYONE_WITH_LINK") file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.EDIT);
    else if (SHARING === "DOMAIN") file.setSharing(DriveApp.Access.DOMAIN_WITH_LINK, DriveApp.Permission.EDIT);
  } catch (e) {}
}
